# caiji-mvp 环境变量示例
# 复制为 .env (本地开发) 或写入 /etc/caiji-mvp.env (生产, chmod 600)
# NEVER commit 实际 secret 到 git, .gitignore 已排除 .env

# === 接收端 (NapCat → caiji): OneBot 11 X-Signature HMAC-SHA1 验签 secret ===
# 生成: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# 配置位置: NapCat WebUI → 网络配置 → HTTP 客户端 → secret 字段
CAIJI_SECRET=

# === 发送端 (caiji → zhaoshang Phase 2) ===
# 待 zhaoshang 加 external_product_candidate 接口后填; 在那之前 ENABLE=0 跳过 sync
# 用同样的 HMAC-SHA1 签名机制 (zhaoshang 侧用同样的 secret 验签)
ENABLE_ZHAOSHANG_SYNC=0
ZHAOSHANG_URL=
ZHAOSHANG_SECRET=
SYNC_INTERVAL_SEC=60
SYNC_BATCH_SIZE=50
SYNC_MAX_ATTEMPTS=5
